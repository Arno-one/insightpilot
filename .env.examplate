# ==================== 应用 ====================
APP_NAME=InsightPilot
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8088

# ==================== MySQL ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=insightpilot

# NL2SQL 只读账号，生产环境建议配置独立只读用户。
MYSQL_READONLY_USER=
MYSQL_READONLY_PASSWORD=

# 兼容旧变量名，如需保留旧脚本可同步配置。
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me
DB_NAME=insightpilot

# ==================== Redis / RQ ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== 鉴权 ====================
AUTH_SECRET_KEY=please-change-to-a-long-random-secret
AUTH_TOKEN_EXPIRE_MINUTES=720
AUTH_PBKDF2_ITERATIONS=600000

# ==================== LLM / NL2SQL ====================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
NL2SQL_MODEL=deepseek-chat

# ==================== DashScope / RAG ====================
DASHSCOPE_API_KEY=
ALIYUN_API_KEY=
MILVUS_URI=http://localhost:19530
MILVUS_DB_NAME=insightpilot_rag
RAG_DOCUMENT_COLLECTION=insightpilot_document_chunks
RAG_QA_COLLECTION=insightpilot_qa_pairs
RAG_DOCS_DIR=docs/insightpilot_rag_docs
EMBEDDING_DIMENSION=1024
USE_REAL_EMBEDDING=true
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50

# ==================== 邮件通知 ====================
SMTP_HOST=
SMTP_PORT=465
SENDER_EMAIL=
SMTP_AUTH_CODE=
SMTP_SENDER_NAME=InsightPilot
SMTP_USE_TLS=true
SMTP_USE_SSL=
SMTP_TIMEOUT_SECONDS=15

# ==================== 前端 ====================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8088
NEXT_DIST_DIR=.next
