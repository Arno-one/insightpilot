# ==================== 应用 ====================
APP_NAME=InsightPilot
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8088

# ==================== MySQL ====================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=你的数据库密码
MYSQL_DATABASE=insightpilot

# ==================== Redis / RQ ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ==================== JWT ====================
AUTH_SECRET_KEY=请改成一个足够长且随机的密钥
AUTH_TOKEN_EXPIRE_MINUTES=720
AUTH_PBKDF2_ITERATIONS=600000

# ==================== DeepSeek ====================
DEEPSEEK_API_KEY=你的DeepSeek密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==================== DashScope Embedding ====================
DASHSCOPE_API_KEY=你的DashScope密钥
ALIYUN_API_KEY=你的DashScope密钥

# ==================== Milvus ====================
MILVUS_URI=http://localhost:19530
MILVUS_DB_NAME=insightpilot_rag

# ==================== RAG ====================
RAG_DOCUMENT_COLLECTION=insightpilot_document_chunks
RAG_QA_COLLECTION=insightpilot_qa_pairs
